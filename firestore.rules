rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'subscriptionTier', 'createdAt']) &&
             data.keys().size() == 4 &&
             data.uid == request.auth.uid &&
             data.email is string &&
             data.subscriptionTier in ['guest', 'pro'] &&
             data.createdAt is timestamp;
    }

    function isAdmin() {
      return isSignedIn() && (
        (request.auth.token.email == 'anwar17070@gmail.com' || request.auth.token.email == 'shahrukh17070@gmail.com') && 
        request.auth.token.email_verified == true
      );
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data) &&
                      request.resource.data.uid == resource.data.uid &&
                      request.resource.data.createdAt == resource.data.createdAt;
    }
  }
}
