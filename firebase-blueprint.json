{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User profile with subscription tier.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "subscriptionTier": { "type": "string", "enum": ["guest", "pro"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "subscriptionTier", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Store user profiles."
    }
  }
}
